{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:network-analytics:harbor-lantern-interchange:v1",
  "title": "Harbor Lantern Interchange V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "fixtureVersion",
    "case",
    "guidedSteps",
    "nodes",
    "relationships",
    "temporalCorrections",
    "lineageScenarios",
    "defaults"
  ],
  "properties": {
    "schema": { "const": "HarborLanternInterchangeV1" },
    "fixtureVersion": { "const": "1.0.0" },
    "case": {
      "type": "object",
      "required": ["id", "displayId", "title", "purpose", "synthetic", "handlingLabel", "question", "scope"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "synthetic": { "const": true },
        "handlingLabel": { "type": "string", "minLength": 1 },
        "question": { "type": "string", "minLength": 1 },
        "scope": {
          "type": "object",
          "required": ["permittedStart", "permittedEnd", "beforeStart", "beforeEnd", "afterStart", "afterEnd", "knownAt"]
        }
      }
    },
    "guidedSteps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "eyebrow", "title", "explanation", "task"]
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "type", "x", "y"]
      }
    },
    "relationships": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/assertion" }
    },
    "temporalCorrections": {
      "type": "array",
      "items": { "$ref": "#/$defs/assertion" }
    },
    "lineageScenarios": {
      "type": "object",
      "required": ["split", "merge", "resurgenceAndBirth"]
    },
    "defaults": {
      "type": "object",
      "required": [
        "aliasIncluded",
        "windowDays",
        "relationFilter",
        "comparisonMode",
        "labelDensity",
        "spacing",
        "highContrast",
        "showCommunities"
      ]
    }
  },
  "$defs": {
    "assertion": {
      "type": "object",
      "required": [
        "assertionId",
        "revisionId",
        "subject",
        "predicateCode",
        "object",
        "assertionClass",
        "confidenceValue",
        "sourceId",
        "source",
        "originalReference",
        "validStart",
        "recordedStart",
        "reliability",
        "credibility",
        "handlingLabel",
        "fieldRestrictions"
      ],
      "properties": {
        "confidenceValue": { "type": "number", "minimum": 0, "maximum": 1 },
        "validStart": { "type": "string", "format": "date-time" },
        "validEnd": { "type": ["string", "null"], "format": "date-time" },
        "recordedStart": { "type": "string", "format": "date-time" },
        "recordedEnd": { "type": ["string", "null"], "format": "date-time" },
        "fieldRestrictions": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    }
  }
}
